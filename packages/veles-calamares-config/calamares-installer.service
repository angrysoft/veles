[Unit]
Description=Calamares Installer Kiosk Mode (Weston)
After=systemd-user-sessions.service plymouth-quit-wait.service systemd-udevd.service systemd-logind.service
Before=getty@tty1.service
Conflicts=getty@tty1.service

[Service]
Type=simple
User=live
WorkingDirectory=/home/live

StandardInput=tty
StandardOutput=journal
StandardError=journal
TTYPath=/dev/tty1
UtmpIdentifier=tty1

Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=QT_QPA_PLATFORM=wayland
Environment=XDG_SEAT=seat0

ExecStartPre=/usr/bin/mkdir -p /run/user/1000
ExecStartPre=/usr/bin/chmod 0700 /run/user/1000

ExecStart=/usr/bin/weston --tty=1 --config=/etc/xdg/weston/weston.ini

Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target